# Biotech Trading Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — safe for client-side / Streamlit dashboard reads
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — trusted backend only (GitHub Actions pipeline writes)
# Never expose this in the browser or commit it to the repo.
SUPABASE_SECRET_KEY=sb_secret_...

# ── EODHD (stock prices & data) ───────────────────────────────────────────────
EODHD_API_KEY=your-eodhd-api-key-here

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by SEC — use your real email address
SEC_CONTACT_EMAIL=your@email.com

# ── MLflow (optional — for experiment tracking) ───────────────────────────────
# Leave blank to skip MLflow logging. Metrics are always saved to Supabase.
# DagsHub example: https://dagshub.com/username/repo.mlflow
MLFLOW_TRACKING_URI=
# DagsHub auth (required if using DagsHub MLflow — find token at dagshub.com/user/settings/tokens)
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# ── Portfolio config (optional overrides) ─────────────────────────────────────
# INITIAL_CAPITAL=1000000.0
# MAX_OPEN_POSITIONS=20
# MAX_WEIGHT=0.07
